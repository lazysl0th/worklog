// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum MeasurementUnit {
  M3
  M2
  M
  TON
  KG
  PCS
  SECTION
}

model WorkType {
  id          String     @id @default(uuid())
  name        String     @unique
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  workLogs    WorkLog[]

  @@map("work_types")
}

model Contractor {
  id          String     @id @default(uuid())
  fullName    String     @map("full_name")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  workLogs    WorkLog[]

  @@map("contractors")
}

model WorkLog {
  id           String          @id @default(uuid())
  date         DateTime        @db.Date
  workTypeId   String          @map("work_type_id")
  workType     WorkType        @relation(fields: [workTypeId], references: [id], onDelete: Restrict)
  volume       Decimal         @db.Decimal(10, 2)
  unit         MeasurementUnit
  contractorId String          @map("contractor_id")
  contractor   Contractor      @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([date])
  @@map("work_logs")
}